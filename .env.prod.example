TZ=Asia/Shanghai

# Docker Hub images (override by workflow at deploy time if needed)
BACKEND_IMAGE=your-dockerhub-username/pet-backend:latest
FRONTEND_IMAGE=your-dockerhub-username/pet-frontend:latest

# Host port
FRONTEND_PORT=3000

# MySQL
MYSQL_DATABASE=pet_health_system
MYSQL_ROOT_PASSWORD=pet_root_pass

# JWT
SECURITY_JWT_SECRET=change-me-please-change-me-please-123456

# Mail (optional)
SPRING_MAIL_HOST=smtp.qq.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=
SPRING_MAIL_PROTOCOL=smtp
SPRING_MAIL_DEBUG=false
